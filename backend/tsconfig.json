{
  "compilerOptions": {
    // 📁 Project structure
    "rootDir": "./src",
    "outDir": "./dist",

    // ⚙️ ESM setup (FIXED)
    "module": "NodeNext",
    "moduleResolution": "NodeNext",
    "target": "ES2022",
    "lib": ["ES2022"],

    // 🌐 Node environment
    "types": ["node"],

    // 🛠️ Output
    "sourceMap": true,
    "declaration": false,
    "removeComments": true,

    // 🔒 Strictness
    "strict": true,
    "noUncheckedIndexedAccess": true,
    "exactOptionalPropertyTypes": true,

    // ⚡ Compatibility
    "esModuleInterop": true,
    "forceConsistentCasingInFileNames": true,
    "isolatedModules": true,

    // 🚀 Performance
    "skipLibCheck": true
  },

  "include": ["src"],

  "exclude": [
    "node_modules",
    "dist",
    "public",
    "uploads",
    "streams",
    "**/*.test.ts"
  ]
}